{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "duty-board",
  "version": "0.1.0",
  "identifier": "org.gewu-asm.duty-board",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420/",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "duty-board",
        "width": 260,
        "height": 80,
        "decorations": false,
        "x": 0,
        "y": 0,
        "alwaysOnTop": true,
        "contentProtected": false,
        "focusable": true,
        "maximizable": false,
        "resizable": false,
        "shadow": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/gewu_shield.ico"
    ]
  }
}