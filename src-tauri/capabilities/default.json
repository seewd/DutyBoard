{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "for all",
  "windows": [
    "*"
  ],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-minimize",
    "core:window:allow-close",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://www.yuque.com/**" }
      ]
    }
  ]
}